{
  "name": "taco-trader",
  "version": "0.1.0",
  "description": "TACO Trader app for evaluating Trump-driven market dips and rebound setups.",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.server.json && vite build",
    "dev": "concurrently -k -n api,web \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite --host 127.0.0.1",
    "dev:server": "PORT=3001 tsx watch src/server.ts",
    "start": "npm run build && node dist/server.js",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.client.json --noEmit"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/three": "^0.184.0",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "three": "^0.184.0"
  }
}
